<Window x:Class="SourceSoundScripter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SourceSoundScripter"
        mc:Ignorable="d"
        Title="Source Sound Scripter" Height="600" Width="750" MinWidth="600" MinHeight="550">
	<Grid AllowDrop="True" DragEnter="Grid_DragEnter" Drop="Grid_Drop">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="20"/>
			<ColumnDefinition Width="110"/>
			<ColumnDefinition Width="110"/>
			<ColumnDefinition Width="100"/>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="110"/>
			<ColumnDefinition Width="10"/>
			<ColumnDefinition Width="120"/>
			<ColumnDefinition Width="10"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="20"/>
			<RowDefinition Height="0"/> <!--30-->
			<RowDefinition Height="0"/> <!--20-->
			<!--Soundscript List-->
			<RowDefinition Height="auto"/>
			<RowDefinition Height="20"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="20"/>
			<!--Defaults-->
			<RowDefinition Height="25"/>
			<RowDefinition Height="25"/>
			<RowDefinition Height="25"/>
			<RowDefinition Height="25"/>
			<RowDefinition Height="25"/>
			<!--Footer-->
			<RowDefinition Height="auto"/>
			<!--<RowDefinition Height="32"/>-->
		</Grid.RowDefinitions>

		<ListView x:Name="SoundscriptList" ItemsSource="{Binding}" Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="5" Grid.RowSpan="6">
			<ListView.View>
				<GridView>
					<GridViewColumn DisplayMemberBinding="{Binding Name}" Header="Name" Width="250" />
					<GridViewColumn DisplayMemberBinding="{Binding DisplayWave}" Header="File" Width="325" />
				</GridView>
			</ListView.View>
			<ListView.ItemContainerStyle>
				<Style TargetType="{x:Type ListViewItem}">
					<!-- Ensure items stretch to fill the width of the ListView -->
					<Setter Property="HorizontalContentAlignment" Value="Stretch" />
					<!-- Add a bottom border (the line) to each item -->
					<Setter Property="BorderThickness" Value="0,0,0,1" />
					<Setter Property="BorderBrush" Value="LightGray" />
				</Style>
			</ListView.ItemContainerStyle>
		</ListView>

		<!-- List Buttons -->
		<Button x:Name="SoundscriptAdd" Grid.Row="5" Grid.Column="7"
				HorizontalAlignment="Stretch"
				FontSize="14" Content="Add Entry"
				Margin="5,5,5,5" Click="SoundscriptAdd_Click"
				ToolTip="Adds a new soundscript entry."/>
		<Button x:Name="SoundscriptAddSounds" Grid.Row="3" Grid.Column="7"
				HorizontalAlignment="Stretch"
				FontSize="14" Content="Add Sounds..."
				Margin="5,5,5,5" Click="SoundscriptAddSounds_Click"
				ToolTip="Adds sounds in batch."/>

		<Button x:Name="SoundscriptEdit" Grid.Row="6" Grid.Column="7"
				HorizontalAlignment="Stretch"
				FontSize="14" Content="Edit Entries..."
				Margin="5,5,5,5" Click="SoundscriptEdit_Click"
				ToolTip="Edits the selected soundscript entries."/>
		<Button x:Name="SoundscriptDelete" Grid.Row="7" Grid.Column="7"
				HorizontalAlignment="Stretch"
				FontSize="14" Content="Delete Entries"
				Margin="5,5,5,5" Click="SoundscriptDelete_Click"
				ToolTip="Deletes the selected soundscript entries."/>

		<!-- Defaults -->
		<TextBlock x:Name="Default_Channel_Txt" Grid.Column="1" Grid.Row="10" Margin="2,2,2,2"
				Text="Default Channel:" FontSize="12" VerticalAlignment="Center"/>
		<ComboBox x:Name="Default_Channel" Grid.Column="2" Grid.Row="10"
				Grid.ColumnSpan="1"
				FontSize="12"
				Margin="2,2,2,2" SelectionChanged="Default_Channel_SelectionChanged">
			<ComboBoxItem Content="CHAN_AUTO" x:Name="Default_Channel_Norm"/>
			<ComboBoxItem Content="CHAN_WEAPON"/>
			<ComboBoxItem Content="CHAN_VOICE" IsSelected="True"/>
			<ComboBoxItem Content="CHAN_VOICE2"/>
			<ComboBoxItem Content="CHAN_ITEM"/>
			<ComboBoxItem Content="CHAN_BODY"/>
			<ComboBoxItem Content="CHAN_STREAM"/>
			<ComboBoxItem Content="CHAN_REPLACE"/>
			<ComboBoxItem Content="CHAN_STATIC"/>
			<ComboBoxItem Content="CHAN_VOICE_BASE"/>
			<ComboBoxItem Content="Custom"/>
		</ComboBox>
		<TextBox x:Name="Default_Channel_Custom" Grid.Column="3" Grid.Row="10"
 				Grid.ColumnSpan="1"
 				FontSize="12"
 				Margin="2,2,2,2" IsEnabled="False"/>

		<TextBlock x:Name="Default_Volume_Txt" Grid.Column="1" Grid.Row="11" Margin="2,2,2,2"
				Text="Default Volume:" FontSize="12" VerticalAlignment="Center"/>
		<ComboBox x:Name="Default_Volume" Grid.Column="2" Grid.Row="11"
 				Grid.ColumnSpan="1"
 				FontSize="12"
 				Margin="2,2,2,2" SelectionChanged="Default_Volume_SelectionChanged">
			<ComboBoxItem Content="VOL_NORM" IsSelected="True" x:Name="Default_Volume_Norm"/>
			<ComboBoxItem Content="Custom"/>
		</ComboBox>
		<TextBox x:Name="Default_Volume_Custom" Grid.Column="3" Grid.Row="11"
				Grid.ColumnSpan="1"
				FontSize="12"
				Margin="2,2,2,2" IsEnabled="False"/>

		<TextBlock x:Name="Default_Pitch_Txt" Grid.Column="1" Grid.Row="12" Margin="2,2,2,2"
				Text="Default Pitch:" FontSize="12" VerticalAlignment="Center"/>
		<ComboBox x:Name="Default_Pitch" Grid.Column="2" Grid.Row="12"
 				Grid.ColumnSpan="1"
 				FontSize="12"
 				Margin="2,2,2,2" SelectionChanged="Default_Pitch_SelectionChanged">
			<ComboBoxItem Content="PITCH_LOW"/>
			<ComboBoxItem Content="PITCH_NORM" IsSelected="True" x:Name="Default_Pitch_Norm"/>
			<ComboBoxItem Content="PITCH_HIGH"/>
			<ComboBoxItem Content="Custom"/>
		</ComboBox>
		<TextBox x:Name="Default_Pitch_Custom" Grid.Column="3" Grid.Row="12"
				Grid.ColumnSpan="1"
				FontSize="12"
				Margin="2,2,2,2" IsEnabled="False"/>

		<TextBlock x:Name="Default_SndLvl_Txt" Grid.Column="1" Grid.Row="13" Margin="2,2,2,2"
				Text="Default Snd Lvl:" FontSize="12" VerticalAlignment="Center"/>
		<ComboBox x:Name="Default_SndLvl" Grid.Column="2" Grid.Row="13"
 				Grid.ColumnSpan="1"
 				FontSize="12"
 				Margin="2,2,2,2" SelectionChanged="Default_SndLvl_SelectionChanged">
			<ComboBoxItem Content="SNDLVL_NONE"/>
			<ComboBoxItem Content="SNDLVL_20dB"/>
			<ComboBoxItem Content="SNDLVL_25dB"/>
			<ComboBoxItem Content="SNDLVL_30dB"/>
			<ComboBoxItem Content="SNDLVL_35dB"/>
			<ComboBoxItem Content="SNDLVL_40dB"/>
			<ComboBoxItem Content="SNDLVL_45dB"/>
			<ComboBoxItem Content="SNDLVL_50dB"/>
			<ComboBoxItem Content="SNDLVL_55dB"/>
			<ComboBoxItem Content="SNDLVL_60dB"/>
			<ComboBoxItem Content="SNDLVL_IDLE"/>
			<ComboBoxItem Content="SNDLVL_65dB"/>
			<ComboBoxItem Content="SNDLVL_STATIC"/>
			<ComboBoxItem Content="SNDLVL_70dB"/>
			<ComboBoxItem Content="SNDLVL_75dB"/>
			<ComboBoxItem Content="SNDLVL_NORM" x:Name="Default_SndLvl_Norm"/>
			<ComboBoxItem Content="SNDLVL_80dB"/>
			<ComboBoxItem Content="SNDLVL_TALKING" IsSelected="True"/>
			<ComboBoxItem Content="SNDLVL_85dB"/>
			<ComboBoxItem Content="SNDLVL_90dB"/>
			<ComboBoxItem Content="SNDLVL_95dB"/>
			<ComboBoxItem Content="SNDLVL_100dB"/>
			<ComboBoxItem Content="SNDLVL_105dB"/>
			<ComboBoxItem Content="SNDLVL_110dB"/>
			<ComboBoxItem Content="SNDLVL_120dB"/>
			<ComboBoxItem Content="SNDLVL_125dB"/>
			<ComboBoxItem Content="SNDLVL_130dB"/>
			<ComboBoxItem Content="SNDLVL_GUNFIRE"/>
			<ComboBoxItem Content="SNDLVL_140dB"/>
			<ComboBoxItem Content="SNDLVL_145dB"/>
			<ComboBoxItem Content="SNDLVL_150dB"/>
			<ComboBoxItem Content="SNDLVL_180dB"/>
			<ComboBoxItem Content="Custom"/>
		</ComboBox>
		<TextBox x:Name="Default_SndLvl_Custom" Grid.Column="3" Grid.Row="13"
				Grid.ColumnSpan="1"
				FontSize="12"
				Margin="2,2,2,2" IsEnabled="False"/>

		<TextBlock x:Name="Default_SndChars_Txt" Grid.Column="1" Grid.Row="14" Margin="2,2,2,2"
				Text="Default Snd Chars:" FontSize="12" VerticalAlignment="Center"/>
		<TextBox x:Name="Default_SndChars_Custom" Grid.Column="2" Grid.Row="14"
				Grid.ColumnSpan="1"
				FontSize="12"
				Margin="2,2,2,2"/>

		<!-- Footer -->
		<Button x:Name="SaveButton" Grid.Row="15" Grid.Column="7"
				HorizontalAlignment="Stretch"
				FontSize="16" Content="Save"
				Margin="5,10,5,10" Click="SaveButton_Click"
				ToolTip="Saves the soundscript file."/>
		<Button x:Name="LoadButton" Grid.Row="15" Grid.Column="5"
				HorizontalAlignment="Stretch"
				FontSize="16" Content="Load"
				Margin="5,10,5,10" Click="LoadButton_Click"
				ToolTip="Loads the soundscript file."/>

		<Button x:Name="DialogueEditorButton" Grid.Row="15" Grid.Column="1" Grid.ColumnSpan="2"
				HorizontalAlignment="Stretch"
				FontSize="16" Content="Dialogue Editor"
				Margin="5,10,5,10" Click="DialogueEditorButton_Click"
				ToolTip="Loads the soundscript file."/>
	</Grid>
</Window>
